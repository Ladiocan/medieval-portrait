# Medieval Portrait Application Environment Variables
# Copy this file to .env and put your actual values in it

# Webhook for basic generation
WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/medieval-souvenir

# WhatsApp phone number (international format, no + prefix)
WHATSAPP_NUMBER=40771229487

# Image upload settings
MAX_IMAGE_SIZE_MB=15
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/heic,image/heif

# Optional donation URL
DONATION_URL=https://www.buymeacoffee.com/TuristinTransilvania

# --- NETOPIA PAYMENTS (XML/RC4/RSA — same as mobilpay) ---
# Download keys from: https://admin.netopia-payments.com/ -> Setări tehnice
# For sandbox: https://sandbox.netopia-payments.com -> Setări tehnice
NETOPIA_SIGNATURE=XXXX-XXXX-XXXX-XXXX-XXXX
NETOPIA_PUBLIC_KEY="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
NETOPIA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
NETOPIA_SANDBOX=true

# Webhook in n8n where Vercel will send the notification when a payment is processed
N8N_WEBHOOK_URL_PAYMENT=https://your-n8n-instance.app.n8n.cloud/webhook/netopia-payment
