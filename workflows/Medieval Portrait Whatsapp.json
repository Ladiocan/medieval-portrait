      "parameters": {
        "jsCode": "// Nod: Prepare Data (Code Node)\n\n// Prelu\u0103m primul item din WhatsApp Trigger\nconst inputItem = $input.item;\n\n// Extragem numele \u0219i WA ID-ul\nconst contact = $node[\"WhatsApp Trigger\"].json.contacts?.[0]?.profile || {};\nconst senderName = contact.name || \"Visitor\";\nconst waId = $node[\"WhatsApp Trigger\"].json.contacts?.[0]?.wa_id || \"\";\n\n// Binary image\nconst binaryKeys = Object.keys(inputItem.binary || {});\nif (binaryKeys.length === 0) {\n  throw new Error(\"\u274c Nu a fost primit niciun fi\u0219ier \u00een binary.\");\n}\n\nlet binaryFile;\nif (inputItem.binary.file) {\n  binaryFile = inputItem.binary.file;\n} else if (inputItem.binary.data) {\n  binaryFile = inputItem.binary.data;\n  inputItem.binary.file = binaryFile;\n  delete inputItem.binary.data;\n} else {\n  throw new Error(\"\u274c Fi\u0219ierul lipse\u0219te complet din binary.\");\n}\n\n// For\u021b\u0103m tipul MIME\nbinaryFile.mimeType = \"image/jpeg\";\n\n// Extragem datele din body\nlet formData = inputItem.json.body || {};\n\nconst normalize = (v) => Array.isArray(v) ? v[0] : v || \"\";\n\n// Alte c\u00e2mpuri din formular\nconst name = senderName;\nconst email = normalize(formData.email) || \"\";\nconst location = normalize(formData.location) || \"\";\nconst title = normalize(formData.title) || \"Noble\";\nconst era = normalize(formData.era) || \"Medieval Times\";\nconst style = normalize(formData.style) || \"Renaissance Portrait\";\n\n// Nume fi\u0219iere\nconst timestamp = new Date().toISOString().replace(/[:.]/g, \"-\");\nconst sanitizedName = name.replace(/[^a-zA-Z0-9]/g, \"-\").toLowerCase();\nconst originalFilename = `original-${sanitizedName}-${timestamp}.jpg`;\nconst aiFilename = `ai-${sanitizedName}-${timestamp}.png`;\n\n// Set\u0103m numele fi\u0219ierului \u00een binary\nbinaryFile.fileName = originalFilename;\n\n// Inject\u0103m \u00een output\ninputItem.json = {\n  name,\n  wa_id: waId,\n  email,\n  title,\n  era,\n  style,\n  location,\n  mimeType: \"image/jpeg\",\n  originalFilename,\n  aiFilename,\n  timestamp,\n  processId: `portrait-${Date.now()}`,\n  bucketPath: `original-uploads/${originalFilename}`,\n  aiBucketPath: `AI-generated/${aiFilename}`\n};\n\nreturn [inputItem];\n"
      },
