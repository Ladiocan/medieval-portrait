        "functionCode": "// Check if the image generation is complete\nconst status = $node[\"HTTP Request\"].json.status;\n\nif (status !== \"succeeded\") {\n  // If not complete, wait longer\n  return { \n    json: { \n      continue: false, \n      error: `Image generation ${status}`,\n      status: status,\n      needsRetry: true\n    } \n  };\n}\n\n// Get the output image URL\nconst outputImageUrl = $node[\"HTTP Request\"].json.output[0] || $node[\"Generate AI Image\"].json.output;\n\n// Return the data with the generated image URL\nreturn {\n  json: {\n    ...$node[\"Get Media URL\"].json,\n    generatedImageUrl: outputImageUrl,\n    continue: true,\n    status: status,\n    needsRetry: false\n  }\n};"
      },
